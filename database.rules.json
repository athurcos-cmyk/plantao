{
  "rules": {
    "owners": {
      "$code": {
        ".read": "auth != null && data.child(auth.uid).exists()",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && (!data.exists() || !newData.exists())"
        }
      }
    },
    "uid_map": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && (!data.exists() || !newData.exists())"
      }
    },
    "usuarios": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "pin": {
          ".read": false
        },
        "nome": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 80)"
        },
        "email": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "criadoEm": {
          ".validate": "newData.isNumber()"
        },
        "plano": {
          ".write": false
        }
      }
    },
    "anotacoes": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".indexOn": ["timestamp"],
        "$id": {
          ".validate": "!newData.exists() || (newData.hasChildren(['tipo', 'texto', 'timestamp']) && newData.child('tipo').isString() && newData.child('texto').isString() && newData.child('timestamp').isNumber() && (!newData.child('nome').exists() || newData.child('nome').isString()) && (!newData.child('leito').exists() || newData.child('leito').isString()))"
        }
      }
    },
    "anotacoes_hc": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true"
      }
    },
    "pacientes": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "$id": {
          ".validate": "!newData.exists() || (newData.hasChildren(['nome', 'criadoEm']) && newData.child('nome').isString() && newData.child('criadoEm').isNumber() && (!newData.child('leito').exists() || newData.child('leito').isString()))",
          "pendencias": {
            "$pend": {
              ".validate": "!newData.exists() || (newData.hasChildren(['texto', 'feito', 'criadoEm']) && newData.child('texto').isString() && newData.child('feito').isBoolean() && newData.child('criadoEm').isNumber() && (!newData.child('horario').exists() || newData.child('horario').isString()))"
            }
          }
        }
      }
    },
    "organizador": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true"
      }
    },
    "encaminhamento": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "destinos": {
          "$id": {
            ".validate": "!newData.exists() || (newData.hasChildren(['texto', 'criadoEm']) && newData.child('texto').isString() && newData.child('criadoEm').isNumber())"
          }
        }
      }
    },
    "livres": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "modelos": {
          "$id": {
            ".validate": "!newData.exists() || (newData.child('texto').isString() && (!newData.child('titulo').exists() || newData.child('titulo').isString()) && (!newData.child('criadoEm').exists() || newData.child('criadoEm').isNumber()))"
          }
        }
      }
    },
    "curativo": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "locais": {
          "$id": {
            ".validate": "!newData.exists() || (newData.hasChildren(['texto', 'criadoEm']) && newData.child('texto').isString() && newData.child('criadoEm').isNumber())"
          }
        },
        "materiais": {
          "$id": {
            ".validate": "!newData.exists() || (newData.hasChildren(['texto', 'criadoEm']) && newData.child('texto').isString() && newData.child('criadoEm').isNumber())"
          }
        }
      }
    },
    "push_subscriptions": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true"
      }
    },
    "fcm_tokens": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true"
      }
    },
    "notificacoes_agendadas": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "agendadas": {
          "$id": {
            ".validate": "!newData.exists() || (newData.hasChildren(['timestamp', 'body']) && newData.child('timestamp').isNumber() && newData.child('body').isString() && (!newData.child('tag').exists() || newData.child('tag').isString()) && (!newData.child('sentAt').exists() || newData.child('sentAt').isNumber()))"
          }
        }
      }
    },
    "configuracoes": {
      "$code": {
        ".read": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true"
      }
    },
    "config": {
      "total_usuarios": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "waitlist": {
      ".read": false,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChildren(['email', 'criadoEm']) && newData.child('email').isString() && newData.child('email').val().length <= 120 && newData.child('criadoEm').isNumber()"
      }
    },
    "feedback": {
      "$code": {
        ".read": false,
        ".write": "auth != null && root.child('owners').child($code).child(auth.uid).val() === true",
        "$id": {
          ".validate": "!newData.exists() || (newData.hasChildren(['texto', 'timestamp']) && newData.child('texto').isString() && newData.child('timestamp').isNumber() && (!newData.child('versaoApp').exists() || newData.child('versaoApp').isString()))"
        }
      }
    }
  }
}
